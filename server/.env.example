DATABASE_URL=postgresql://loanofficer:loanofficer@localhost:5432/loanofficer
REDIS_URL=redis://localhost:6379
PORT=4000
APP_BASE_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
EXTERNAL_APPLICATION_URL=https://example.com/apply
ALLOWED_ORIGINS=http://localhost:3000

OPENAI_API_KEY=

# Outbound email (Resend API)
RESEND_API_KEY=
EMAIL_FROM="Loan Team <noreply@example.com>"

# HTML email signature (optional pieces omitted if unset; use HTTPS URLs for images)
# Served from Next.js /public — set on Railway API to your web origin, e.g.:
#   SIGNATURE_IMAGE_URL=https://karipastrana.com/images/headshot.jpg
#   SIGNATURE_BUTTON_IMAGE_URL=https://karipastrana.com/images/apply-button.jpg
# Local: http://localhost:3000/images/headshot.jpg
LOAN_OFFICER_NAME=Kari Pastrana
LOAN_OFFICER_EMAIL=kari.pastrana@novushomemortgage.com
LOAN_OFFICER_PHONE=(850) 420-7731
SIGNATURE_IMAGE_URL=
SIGNATURE_BUTTON_IMAGE_URL=
COMPANY_WEBSITE=https://novushomemortgage.com
COMPANY_ADDRESS=20225 Water Tower Blvd, Suite 400, Brookfield, WI 53045

# Gmail API (OAuth Web client)
# Redirect URI must match Google Cloud Console "Authorized redirect URIs" exactly (no hardcoding in code).
# Local with Next.js rewrites to API:  http://localhost:3000/api/google/callback
# Or call API directly:                http://localhost:4000/api/google/callback
# Railway (public web origin):         https://YOUR_DOMAIN/api/google/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/google/callback
# Optional if you complete OAuth via GET /api/auth/google — refresh token is also stored in DB (gmail_oauth_tokens)
GMAIL_REFRESH_TOKEN=

# Auto Gmail polling interval in minutes (clamped to 2-5)
AUTO_POLL_MINUTES=3

# Max outbound emails per lead per 24h (safety)
MAX_EMAILS_PER_LEAD_PER_DAY=8
MIN_MINUTES_BETWEEN_SENDS=5

# Auth (loan officer dashboard/API)
SESSION_COOKIE_NAME=loancrm_session
SESSION_SECRET=change-this-in-production
SESSION_TTL_HOURS=12
AUTH_SEED_EMAIL=officer@example.com
AUTH_SEED_PASSWORD=change-this-password

# Basic API rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PER_WINDOW=120
