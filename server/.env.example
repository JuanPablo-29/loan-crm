DATABASE_URL=postgresql://loanofficer:loanofficer@localhost:5432/loanofficer
REDIS_URL=redis://localhost:6379
PORT=4000
APP_BASE_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
EXTERNAL_APPLICATION_URL=https://example.com/apply
ALLOWED_ORIGINS=http://localhost:3000

OPENAI_API_KEY=

# Outbound email (Resend API)
RESEND_API_KEY=
EMAIL_FROM="Loan Team <noreply@example.com>"

# Gmail API (OAuth)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Auto Gmail polling interval in minutes (clamped to 2-5)
AUTO_POLL_MINUTES=3

# Max outbound emails per lead per 24h (safety)
MAX_EMAILS_PER_LEAD_PER_DAY=8
MIN_MINUTES_BETWEEN_SENDS=5

# Auth (loan officer dashboard/API)
SESSION_COOKIE_NAME=loancrm_session
SESSION_SECRET=change-this-in-production
SESSION_TTL_HOURS=12
AUTH_SEED_EMAIL=officer@example.com
AUTH_SEED_PASSWORD=change-this-password

# Basic API rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PER_WINDOW=120
